/**root {
  --primary-color: #007AFF;
  --success-color: #34C759;
  --warning-color: #FF9500;
  --danger-color: #FF3B30;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-weak: #999999;
  --bg-primary: #FFFFFF;
  --bg-secondary: #F5F5F5;
  --border-color: #E5E5E5;
}

page {
  background-color: var(--bg-secondary);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
  color: var(--text-primary);
}

.container {
  padding: 32rpx;
  padding-bottom: 120rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 32rpx;
  color: var(--text-primary);
}

.card {
  background: var(--bg-primary);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  background: var(--primary-color);
  color: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin-top: 32rpx;
}

.btn-primary:active {
  opacity: 0.8;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  border: 1px solid var(--border-color);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  background: var(--bg-primary);
}

.tag-self {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: var(--danger-color);
  color: #fff;
  font-size: 20rpx;
  border-radius: 8rpx;
  margin-left: 8rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: var(--text-weak);
  font-size: 28rpx;
}
