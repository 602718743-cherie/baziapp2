/* 全局样式 - 仿古宣纸风格 */
page {
  background-color: #f5efe3;
  font-family: "STKaiti", "KaiTi", "STSong", "SimSun", sans-serif;
  color: #3a2a18;
}

.container {
  padding: 20rpx 24rpx;
  padding-bottom: 120rpx;
}

/* 通用卡片 */
.card {
  background: #fffdf7;
  border: 1rpx solid #e2d5be;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

/* 通用标题行 */
.section-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #6b3a1f;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}
.section-title::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 28rpx;
  background: #8B4513;
  border-radius: 3rpx;
  margin-right: 12rpx;
}

/* 通用主按钮 */
.btn-primary {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #a0522d, #8B4513);
  color: #fff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  letter-spacing: 4rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(139,69,19,0.3);
  font-family: inherit;
}
.btn-primary:active { opacity: 0.85; }

/* 通用表单项 */
.form-item { margin-bottom: 20rpx; }
.form-label {
  font-size: 24rpx;
  color: #7a6040;
  margin-bottom: 8rpx;
  display: block;
}
.form-input, .picker {
  width: 100%;
  height: 72rpx;
  border: 1rpx solid #d4c4a8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  background: #fffdf7;
  color: #3a2a18;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

/* 标签 */
.tag-self {
  display: inline-block;
  padding: 4rpx 14rpx;
  background: #8B4513;
  color: #fff;
  font-size: 20rpx;
  border-radius: 10rpx;
  margin-left: 8rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: #9b8165;
  font-size: 26rpx;
  line-height: 2;
}
