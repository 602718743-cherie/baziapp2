<!--pages/my/my.wxml-->
<view class="container">

  <view class="my-header">
    <view class="my-header-title">我的命主</view>
  </view>

  <button class="btn-primary" style="margin-bottom:16rpx" bindtap="onAddPerson">新增命主</button>

  <!-- 人员列表 -->
  <view wx:if="{{persons.length > 0}}">
    <view class="person-card" wx:for="{{persons}}" wx:key="id">
      <view class="person-top">
        <view class="person-avatar"></view>
        <view class="person-right">
          <view class="person-name">
            {{item.name}}
            <text wx:if="{{item.isSelf}}" class="tag-self">本人</text>
          </view>
          <view class="person-detail">{{item.birthDay}} {{item.birthTime}}</view>
          <view class="person-wx">日元：{{item.mainWuxingDisplay || ''}}</view>
        </view>
      </view>
      <view class="person-btns">
        <button class="btn-edit" bindtap="onEditPerson" data-id="{{item.id}}">编辑</button>
        <button class="btn-delete" bindtap="onDeletePerson" data-id="{{item.id}}">删除</button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    暂无命主信息，点击"新增命主"添加
  </view>

</view>

<!-- 编辑弹窗 -->
<view class="modal" wx:if="{{showModal}}">
  <view class="modal-mask" bindtap="onCloseModal"></view>
  <view class="modal-box">
    <view class="modal-title">{{modalTitle}}</view>

    <view class="form-item">
      <view class="form-label">姓名 / 昵称</view>
      <input class="form-input" value="{{formData.name}}" placeholder="请输入命主昵称" bindinput="onNameInput"/>
    </view>
    <view class="form-item">
      <view class="form-label">出生日期</view>
      <picker mode="date" value="{{formData.birthDay}}" bindchange="onBirthDayChange">
        <view class="picker">{{formData.birthDay || '请选择出生日期'}}</view>
      </picker>
    </view>
    <view class="form-item">
      <view class="form-label">出生时间</view>
      <picker mode="time" value="{{formData.birthTime}}" bindchange="onBirthTimeChange">
        <view class="picker">{{formData.birthTime || '请选择出生时间'}}</view>
      </picker>
    </view>
    <view class="form-item form-switch-row">
      <view class="form-label" style="margin-bottom:0">标记为本人</view>
      <switch checked="{{formData.isSelf}}" bindchange="onIsSelfChange" color="#8B4513"/>
    </view>

    <view class="modal-btns">
      <button class="btn-cancel" bindtap="onCloseModal">取消</button>
      <button class="btn-confirm" bindtap="onSavePerson">确认保存</button>
    </view>
  </view>
</view>
