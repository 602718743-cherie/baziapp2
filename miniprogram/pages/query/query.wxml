<!--pages/query/query.wxml-->
<view class="container">

  <!-- 头部标题 -->
  <view class="query-header">
    <view class="header-title">五行穿衣每日指南</view>
    <view class="header-sub">以八字论穿衣 · 趋吉避凶每一天</view>
  </view>

  <!-- 今日日期卡片 -->
  <view class="today-card">
    <view class="today-row">
      <view class="today-day">{{todayDay}}</view>
      <view class="today-info">
        <view class="today-ym">{{todayYear}}年</view>
        <view class="today-ym">{{todayMonth}}月</view>
        <view class="today-ym">{{todayWeekday}}</view>
      </view>
      <view class="today-weekday-big">{{todayWeekday}}</view>
    </view>
    <view class="today-ganzhi">今日干支：{{todayGanZhi}}</view>
  </view>

  <!-- 查询类型 -->
  <view class="card">
    <view class="section-title">选择查询周期</view>
    <view class="tabs">
      <view class="tab {{queryType === 'today' ? 'active' : ''}}" bindtap="switchQueryType" data-type="today">今日运势</view>
      <view class="tab {{queryType === 'week' ? 'active' : ''}}" bindtap="switchQueryType" data-type="week">本周运势</view>
    </view>

    <!-- 选择命主 -->
    <view class="form-item">
      <view class="form-label">👤 选择已保存命主</view>
      <picker mode="selector" range="{{persons}}" range-key="displayName" value="{{selectedIndex}}" bindchange="onPersonChange">
        <view class="picker">
          <text>{{selectedPerson ? selectedPerson.name : '请选择命主'}}</text>
          <text wx:if="{{selectedPerson && selectedPerson.isSelf}}" class="tag-self">本人</text>
        </view>
      </picker>
    </view>

    <!-- 出生日期 -->
    <view class="form-item">
      <view class="form-label">🎂 出生日期</view>
      <picker mode="date" value="{{birthDay}}" bindchange="onBirthDayChange">
        <view class="picker">{{birthDay || '请选择出生日期'}}</view>
      </picker>
    </view>

    <!-- 出生时间 -->
    <view class="form-item">
      <view class="form-label">🕐 出生时间</view>
      <picker mode="time" value="{{birthTime}}" bindchange="onBirthTimeChange">
        <view class="picker">{{birthTime || '请选择出生时间'}}</view>
      </picker>
    </view>

    <button class="btn-primary" bindtap="onQuery">立即查询</button>
  </view>

</view>
