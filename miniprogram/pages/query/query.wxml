<!--pages/query/query.wxml-->
<view class="container">
  <view class="title">运势查询</view>

  <!-- 查询类型切换 -->
  <view class="tabs">
    <view class="tab {{queryType === 'today' ? 'active' : ''}}" bindtap="switchQueryType" data-type="today">
      今日
    </view>
    <view class="tab {{queryType === 'week' ? 'active' : ''}}" bindtap="switchQueryType" data-type="week">
      本周
    </view>
  </view>

  <!-- 查询表单 -->
  <view class="card">
    <!-- 选择已保存人员 -->
    <view class="form-item">
      <label class="form-label">选择已保存人员</label>
      <picker mode="selector" range="{{persons}}" range-key="name" value="{{selectedPersonId}}" bindchange="onPersonChange">
        <view class="picker">
          {{selectedPerson ? selectedPerson.name : '请选择'}}
          <text wx:if="{{selectedPerson && selectedPerson.isSelf}}" class="tag-self">本人</text>
        </view>
      </picker>
    </view>

    <!-- 临时输入入口 -->
    <view class="temp-input-btn" bindtap="onTempInput">
      或 临时输入命主信息
    </view>

    <!-- 出生日期 -->
    <view class="form-item">
      <label class="form-label">出生日期</label>
      <picker mode="date" value="{{birthDay}}" bindchange="onBirthDayChange">
        <view class="picker">{{birthDay || '请选择出生日期'}}</view>
      </picker>
    </view>

    <!-- 出生时间 -->
    <view class="form-item">
      <label class="form-label">出生时间</label>
      <picker mode="time" value="{{birthTime}}" bindchange="onBirthTimeChange">
        <view class="picker">{{birthTime || '请选择出生时间'}}</view>
      </picker>
    </view>

    <!-- 查询按钮 -->
    <button class="btn-primary" bindtap="onQuery">立即查询</button>
  </view>
</view>
