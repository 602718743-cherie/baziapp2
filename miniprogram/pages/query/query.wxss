/* pages/query/query.wxss */
.tabs {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  background: var(--bg-primary);
  border-radius: 16rpx;
  font-size: 30rpx;
  color: var(--text-secondary);
  transition: all 0.3s;
}

.tab.active {
  background: var(--primary-color);
  color: #fff;
  font-weight: 500;
}

.picker {
  width: 100%;
  height: 88rpx;
  border: 1px solid var(--border-color);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  background: var(--bg-primary);
}

.temp-input-btn {
  text-align: center;
  color: var(--primary-color);
  font-size: 28rpx;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
}
