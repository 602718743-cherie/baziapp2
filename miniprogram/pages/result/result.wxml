<!--pages/result/result.wxml-->
<view class="container">
  <!-- 返回按钮 -->
  <view class="back-btn" bindtap="onBack">
    ← 返回
  </view>

  <!-- 命主基础信息 -->
  <view class="card info-card">
    <view class="info-title">命主信息</view>
    <view class="info-item">
      <text class="info-label">八字：</text>
      <text class="info-value">{{result.bazi}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">命主五行：</text>
      <text class="info-value">{{result.mainWuxingDisplay}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">对应色系：</text>
      <text class="info-value">{{result.mainColor}}</text>
    </view>
  </view>

  <!-- 今日运势 -->
  <view wx:if="{{type === 'today'}}" class="card">
    <view class="result-title">今日穿衣建议</view>
    <view class="result-date">{{result.today.date}} {{result.today.weekday}}</view>
    <view class="result-day-wuxing">当日五行：{{result.today.wuxingDisplay}}</view>

    <view class="advice-section">
      <view class="advice-item">
        <view class="advice-label suitable">适合</view>
        <view class="advice-colors">
          <view class="color-tag suitable" wx:for="{{result.today.suitable}}" wx:key="index">
            {{item}}
          </view>
          <text wx:if="{{result.today.suitable.length === 0}}" class="empty-tip">—</text>
        </view>
      </view>

      <view class="advice-item">
        <view class="advice-label unsuitable">不适合</view>
        <view class="advice-colors">
          <view class="color-tag unsuitable" wx:for="{{result.today.unsuitable}}" wx:key="index">
            {{item}}
          </view>
          <text wx:if="{{result.today.unsuitable.length === 0}}" class="empty-tip">—</text>
        </view>
      </view>

      <view class="advice-item">
        <view class="advice-label normal">平</view>
        <view class="advice-colors">
          <view class="color-tag normal" wx:for="{{result.today.normal}}" wx:key="index">
            {{item}}
          </view>
          <text wx:if="{{result.today.normal.length === 0}}" class="empty-tip">—</text>
        </view>
      </view>
    </view>

    <view class="divider"></view>

    <view class="detail-info">
      <view class="detail-item">
        <text class="detail-label">心情状态：</text>
        <text class="detail-value">{{result.today.mood}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">活动建议：</text>
        <text class="detail-value">{{result.today.activity}}</text>
      </view>
    </view>
  </view>

  <!-- 本周运势 -->
  <view wx:if="{{type === 'week'}}" class="card">
    <view class="result-title">本周穿衣建议</view>

    <view class="week-item" wx:for="{{result.week}}" wx:key="date">
      <view class="week-header">
        <text class="week-date">{{item.date.slice(5)}}（{{item.weekday}}）</text>
        <text class="week-wuxing">{{item.wuxingDisplay}}</text>
      </view>

      <view class="week-advice">
        <view class="week-advice-row">
          <text class="week-label suitable">适合：</text>
          <text class="week-value">{{item.suitable.join('、')}}</text>
        </view>
        <view class="week-advice-row">
          <text class="week-label unsuitable">不适合：</text>
          <text class="week-value">{{item.unsuitable.join('、')}}</text>
        </view>
        <view class="week-advice-row">
          <text class="week-label normal">平：</text>
          <text class="week-value">{{item.normal.join('、')}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
