<!--pages/result/result.wxml-->
<view class="result-container">

  <!-- 标题 -->
  <view class="result-page-title">{{pageTitle}}</view>

  <!-- 头部 -->
  <view class="result-header">
    <view class="result-today-row">
      <view class="result-day">{{dateDay}}</view>
      <view class="result-date-info">
        <view class="result-ym">{{dateYear}}年</view>
        <view class="result-ym">{{dateMonth}}月</view>
        <view class="result-ym">{{dateWeekday}}</view>
      </view>
      <view class="result-weekday-big">{{dateWeekday}}</view>
    </view>
    <view class="result-ganzhi">干支：{{result.today ? result.today.ganZhi : dateGanZhi}} · 命主：{{result.mainWuxingDisplay}} · {{birthDay}}</view>
  </view>

  <view class="result-body">

    <!-- 今日穿衣 -->
    <view wx:if="{{type === 'today'}}">

      <!-- 穿衣建议 section -->
      <view class="section-block">
        <view class="section-title">今日穿衣建议</view>

        <!-- 吉 -->
        <view class="advice-row" wx:if="{{todayAdvice.ji.length > 0}}">
          <view class="row-dot ji-dot"></view>
          <view class="row-body">
            <view class="row-title ji-text">吉《贵人色》</view>
            <view class="row-colors">
              <view wx:for="{{todayAdvice.ji}}" wx:key="*this" class="color-swatch-wrap">
                <view class="color-swatch" style="background:{{colorMap[item]}}"></view>
                <text class="swatch-label">{{item}}</text>
              </view>
            </view>
            <view class="row-desc">{{todayAdvice.descs.ji}}</view>
          </view>
        </view>

        <!-- 次吉 -->
        <view class="advice-row" wx:if="{{todayAdvice.ciji.length > 0}}">
          <view class="row-dot ciji-dot"></view>
          <view class="row-body">
            <view class="row-title ciji-text">次吉《合作色》</view>
            <view class="row-colors">
              <view wx:for="{{todayAdvice.ciji}}" wx:key="*this" class="color-swatch-wrap">
                <view class="color-swatch" style="background:{{colorMap[item]}}"></view>
                <text class="swatch-label">{{item}}</text>
              </view>
            </view>
            <view class="row-desc">{{todayAdvice.descs.ciji}}</view>
          </view>
        </view>

        <!-- 平 -->
        <view class="advice-row" wx:if="{{todayAdvice.ping.length > 0}}">
          <view class="row-dot ping-dot"></view>
          <view class="row-body">
            <view class="row-title ping-text">平</view>
            <view class="row-colors">
              <view wx:for="{{todayAdvice.ping}}" wx:key="*this" class="color-swatch-wrap">
                <view class="color-swatch" style="background:{{colorMap[item]}}"></view>
                <text class="swatch-label">{{item}}</text>
              </view>
            </view>
            <view class="row-desc">{{todayAdvice.descs.ping}}</view>
          </view>
        </view>

        <!-- 较差 -->
        <view class="advice-row" wx:if="{{todayAdvice.jiacha.length > 0}}">
          <view class="row-dot jiacha-dot"></view>
          <view class="row-body">
            <view class="row-title jiacha-text">较差《消耗色》</view>
            <view class="row-colors">
              <view wx:for="{{todayAdvice.jiacha}}" wx:key="*this" class="color-swatch-wrap">
                <view class="color-swatch" style="background:{{colorMap[item]}}"></view>
                <text class="swatch-label">{{item}}</text>
              </view>
            </view>
            <view class="row-desc">{{todayAdvice.descs.jiacha}}</view>
          </view>
        </view>

        <!-- 不宜 -->
        <view class="advice-row" wx:if="{{todayAdvice.buyi.length > 0}}">
          <view class="row-dot buyi-dot"></view>
          <view class="row-body">
            <view class="row-title buyi-text">不宜《不利色》</view>
            <view class="row-colors">
              <view wx:for="{{todayAdvice.buyi}}" wx:key="*this" class="color-swatch-wrap">
                <view class="color-swatch" style="background:{{colorMap[item]}}"></view>
                <text class="swatch-label">{{item}}</text>
              </view>
            </view>
            <view class="row-desc">{{todayAdvice.descs.buyi}}</view>
          </view>
        </view>
      </view>

      <!-- 出行建议 section（同层级） -->
      <view class="section-block">
        <view class="section-title">今日出行建议</view>
        <view class="advice-row">
          <view class="row-dot mood-dot"></view>
          <view class="row-body">
            <view class="row-title mood-text">心情状态</view>
            <view class="row-desc">{{result.today.mood}}</view>
          </view>
        </view>
        <view class="advice-row">
          <view class="row-dot goyi-dot"></view>
          <view class="row-body">
            <view class="row-title goyi-text">出行宜</view>
            <view class="row-desc">{{result.today.activity}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 本周运势 -->
    <view wx:if="{{type === 'week'}}">
      <view class="section-block">
        <view class="section-title">本周穿衣 · 出行建议</view>
        <view class="week-card" wx:for="{{result.week}}" wx:key="date">
          <view class="week-header">
            <view class="week-date">{{item.dateDisplay}}（{{item.weekday}}）</view>
            <view class="week-wx-tag">{{item.wuxingDisplay}}</view>
          </view>
          <view class="week-colors">
            <view wx:if="{{item.ji.length > 0}}" class="week-row">
              <text class="week-label ji-text">吉：</text>
              <view wx:for="{{item.ji}}" wx:key="*this" wx:for-item="c" class="color-swatch-wrap">
                <view class="color-swatch-sm" style="background:{{colorMapRef[c]}}"></view>
                <text class="swatch-label-sm">{{c}}</text>
              </view>
            </view>
            <view wx:if="{{item.ciji.length > 0}}" class="week-row">
              <text class="week-label ciji-text">次吉：</text>
              <view wx:for="{{item.ciji}}" wx:key="*this" wx:for-item="c" class="color-swatch-wrap">
                <view class="color-swatch-sm" style="background:{{colorMapRef[c]}}"></view>
                <text class="swatch-label-sm">{{c}}</text>
              </view>
            </view>
            <view wx:if="{{item.ping.length > 0}}" class="week-row">
              <text class="week-label ping-text">平：</text>
              <view wx:for="{{item.ping}}" wx:key="*this" wx:for-item="c" class="color-swatch-wrap">
                <view class="color-swatch-sm" style="background:{{colorMapRef[c]}}"></view>
                <text class="swatch-label-sm">{{c}}</text>
              </view>
            </view>
            <view wx:if="{{item.jiacha.length > 0}}" class="week-row">
              <text class="week-label jiacha-text">较差：</text>
              <view wx:for="{{item.jiacha}}" wx:key="*this" wx:for-item="c" class="color-swatch-wrap">
                <view class="color-swatch-sm" style="background:{{colorMapRef[c]}}"></view>
                <text class="swatch-label-sm">{{c}}</text>
              </view>
            </view>
            <view wx:if="{{item.buyi.length > 0}}" class="week-row">
              <text class="week-label buyi-text">不宜：</text>
              <view wx:for="{{item.buyi}}" wx:key="*this" wx:for-item="c" class="color-swatch-wrap">
                <view class="color-swatch-sm" style="background:{{colorMapRef[c]}}"></view>
                <text class="swatch-label-sm">{{c}}</text>
              </view>
            </view>
          </view>
          <view class="week-go">{{item.mood}} · {{item.activity}}</view>
        </view>
      </view>
    </view>

  </view>
</view>
