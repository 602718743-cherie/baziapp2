/* pages/result/result.wxss */
.result-container {
  background: #f5efe3;
  min-height: 100vh;
}

/* 头部 - 与查询页 today-card 结构一致 */
.result-header {
  background: linear-gradient(135deg, #fdf6e8, #f5ead0);
  border: 1rpx solid #d4b896;
  margin: 16rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 20rpx 28rpx 16rpx;
}
.result-today-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 10rpx; }
.result-day { font-size: 88rpx; font-weight: bold; color: #8B4513; line-height: 1; }
.result-date-info { flex: 1; }
.result-ym { font-size: 22rpx; color: #6b4226; line-height: 1.7; }
.result-weekday-big { font-size: 34rpx; font-weight: bold; color: #8B4513; }
.result-ganzhi {
  font-size: 22rpx; color: #9b7455; letter-spacing: 2rpx;
  border-top: 1rpx dashed #d4b896; padding-top: 10rpx;
}

/* 页面标题 */
.result-page-title {
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #6b3a1f;
  letter-spacing: 4rpx;
  padding: 20rpx 0 8rpx;
}

/* body */
.result-body { padding: 16rpx 24rpx 100rpx; }

/* section块 - 统一容器（穿衣和出行同层级） */
.section-block {
  background: #fffdf7;
  border: 1rpx solid #e2d5be;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 26rpx; font-weight: bold; color: #6b3a1f;
  letter-spacing: 4rpx; margin-bottom: 12rpx;
  display: flex; align-items: center;
}
.section-title::before {
  content: '';
  display: inline-block;
  width: 6rpx; height: 28rpx;
  background: #8B4513; border-radius: 3rpx; margin-right: 12rpx;
}

/* 每条建议行 */
.advice-row {
  display: flex; gap: 16rpx; align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1rpx dashed #efe4d0;
}
.advice-row:last-child { border-bottom: none; padding-bottom: 0; }

/* 左侧色点 - 统一 18rpx */
.row-dot {
  width: 18rpx; height: 18rpx; border-radius: 50%; flex-shrink: 0; margin-top: 8rpx;
}
.ji-dot     { background: #2ecc71; }
.ciji-dot   { background: #3498db; }
.ping-dot   { background: #f0c430; }
.jiacha-dot { background: #aaaaaa; }
.buyi-dot   { background: #e74c3c; }
.mood-dot   { background: #9b59b6; }
.goyi-dot   { background: #27ae60; }

/* 右侧内容 - 统一字号 */
.row-body { flex: 1; min-width: 0; }
.row-title { font-size: 24rpx; font-weight: bold; margin-bottom: 6rpx; line-height: 1.3; }
.ji-text    { color: #1a8a4a; }
.ciji-text  { color: #1a68a8; }
.ping-text  { color: #a07c10; }
.jiacha-text{ color: #666; }
.buyi-text  { color: #c0392b; }
.mood-text  { color: #7b3fa0; }
.goyi-text  { color: #1a7a40; }
.row-desc { font-size: 22rpx; color: #7a6a58; line-height: 1.6; }

/* 颜色小色块 */
.row-colors { display: flex; flex-wrap: wrap; gap: 8rpx; align-items: center; margin-bottom: 6rpx; }
.color-swatch-wrap { display: flex; align-items: center; gap: 6rpx; margin-right: 4rpx; }
.color-swatch {
  width: 24rpx; height: 24rpx; border-radius: 6rpx;
  border: 1rpx solid rgba(0,0,0,0.1); flex-shrink: 0;
}
.swatch-label { font-size: 22rpx; color: #5a4a38; }

/* 周运势 */
.week-card {
  background: #fdf8f0; border: 1rpx solid #ecdcbe;
  border-radius: 16rpx; padding: 16rpx; margin-bottom: 12rpx;
}
.week-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 10rpx; padding-bottom: 10rpx;
  border-bottom: 1rpx dashed #e2d5be;
}
.week-date { font-size: 26rpx; font-weight: bold; color: #6b3a1f; }
.week-wx-tag {
  font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 20rpx;
  background: #f5ede0; color: #8B4513; border: 1rpx solid #d4b896;
}
.week-colors { margin-bottom: 8rpx; }
.week-row { display: flex; align-items: center; gap: 8rpx; margin-bottom: 6rpx; flex-wrap: wrap; }
.week-label { font-size: 22rpx; font-weight: bold; flex-shrink: 0; }
.color-swatch-sm {
  width: 18rpx; height: 18rpx; border-radius: 4rpx;
  border: 1rpx solid rgba(0,0,0,0.1);
}
.swatch-label-sm { font-size: 20rpx; color: #5a4a38; margin-right: 4rpx; }
.week-go-row {
  display: flex; align-items: flex-start; margin-top: 8rpx;
}
.week-go-label {
  font-size: 22rpx; font-weight: bold; white-space: nowrap; margin-right: 4rpx;
}
.week-go-val {
  font-size: 22rpx; color: #7a6a58; line-height: 1.5; flex: 1;
}
.week-divider {
  margin: 14rpx 0 10rpx;
  border-top: 1rpx dashed #d4c4a8;
}
.week-go-sep { color: #c0aa88; }
.week-go {
  font-size: 22rpx; color: #7a6a58; line-height: 1.6;
  padding-top: 8rpx; border-top: 1rpx dashed #e8dcc8;
}
